package com.example.demo.user;

import java.time.LocalDateTime;

import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;

@Entity
@Table(name="User_Sessions")
public class UserSession {
	@Id
	@GeneratedValue(strategy=GenerationType.IDENTITY)
	private Long Id;
	private String userId;
	private String jwtId;
	private String webSocketSessionId;
	private String status;
	private LocalDateTime loginTime;
	private LocalDateTime lastSeen;
	
	
	
	public UserSession() {
		super();
	}



	public UserSession(Long id, String userId, String jwtId, String webSocketSessionId, String status,
			LocalDateTime loginTime, LocalDateTime lastSeen) {
		super();
		Id = id;
		this.userId = userId;
		this.jwtId = jwtId;
		this.webSocketSessionId = webSocketSessionId;
		this.status = status;
		this.loginTime = loginTime;
		this.lastSeen = lastSeen;
	}



	Long getId() {
		return Id;
	}



	void setId(Long id) {
		Id = id;
	}



	String getUserId() {
		return userId;
	}



	void setUserId(String userId) {
		this.userId = userId;
	}



	String getJwtId() {
		return jwtId;
	}



	void setJwtId(String jwtId) {
		this.jwtId = jwtId;
	}



	String getWebSocketSessionId() {
		return webSocketSessionId;
	}



	void setWebSocketSessionId(String webSocketSessionId) {
		this.webSocketSessionId = webSocketSessionId;
	}



	String getStatus() {
		return status;
	}



	void setStatus(String status) {
		this.status = status;
	}



	LocalDateTime getLoginTime() {
		return loginTime;
	}



	void setLoginTime(LocalDateTime loginTime) {
		this.loginTime = loginTime;
	}



	LocalDateTime getLastSeen() {
		return lastSeen;
	}



	void setLastSeen(LocalDateTime lastSeen) {
		this.lastSeen = lastSeen;
	}



	@Override
	public String toString() {
		return "UserSession [Id=" + Id + ", userId=" + userId + ", jwtId=" + jwtId + ", webSocketSessionId="
				+ webSocketSessionId + ", status=" + status + ", loginTime=" + loginTime + ", lastSeen=" + lastSeen
				+ "]";
	}
	
}
